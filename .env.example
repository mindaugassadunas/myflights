# ---------------------------------------------------------------------------
# Aloft — environment variables
# Copy to `.env` at the repo root. Each sub-app (web/, api/) reads what it needs.
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres) -----------------------------------------------
# Pooled URL for the Next.js app (PgBouncer / Neon pooled connection).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connection_limit=1"
# Direct URL for Prisma migrations.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- NextAuth ---------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""              # openssl rand -base64 32
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
OWNER_EMAIL="mindaugas.sadunas@turingcollege.com"   # the only email allowed to sign in

# --- OpenSky (OAuth2 client credentials) ------------------------------------
OPENSKY_CLIENT_ID=""
OPENSKY_CLIENT_SECRET=""
OPENSKY_TOKEN_URL="https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token"
OPENSKY_API_BASE="https://opensky-network.org/api"
OPENSKY_DAILY_CREDIT_BUDGET=4000

# --- AeroDataBox (RapidAPI) — flight-number schedule lookup -----------------
# Used by the add-flight flow to auto-resolve route from flight number + date.
# Subscribe at https://rapidapi.com/aedbx-aedbx/api/aerodatabox (free tier
# covers ~500 requests/month).
AERODATABOX_API_KEY=""
AERODATABOX_HOST="aerodatabox.p.rapidapi.com"

# --- Claude API -------------------------------------------------------------
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-7"

# --- Gmail OAuth (for email import) -----------------------------------------
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REDIRECT_URI="http://localhost:3000/api/integrations/gmail/callback"

# --- API <-> Web shared secret ----------------------------------------------
# Used for internal calls between the Next.js app and the FastAPI worker.
INTERNAL_API_KEY=""
NEXT_PUBLIC_API_BASE_URL="http://localhost:8000"

# --- Misc -------------------------------------------------------------------
LOG_LEVEL="info"
